{
  "name": "wms-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --experimental-build-mode=compile",
    "build:generate": "next build --experimental-build-mode=generate",
    "start": "next start",
    "lint": "eslint",
    "ci:validate-env": "node scripts/ci/validate-env.mjs",
    "ci:auth-domain-guard": "node scripts/ci/auth-domain-guard.mjs",
    "db:migrate": "node scripts/db/run-with-env.mjs scripts/db/migrate.mjs",
    "db:seed": "node scripts/db/run-with-env.mjs scripts/db/seed.mjs",
    "db:reconcile-do:dry": "node scripts/db/run-with-env.mjs scripts/db/reconcile-do-quantities.mjs",
    "db:reconcile-do:apply": "node scripts/db/run-with-env.mjs scripts/db/reconcile-do-quantities.mjs --apply",
    "test:chaos": "node scripts/db/run-with-env.mjs tests/chaos/index.mjs",
    "test:isolation": "node scripts/db/run-with-env.mjs tests/chaos/isolation.mjs",
    "test:resilience": "node scripts/db/run-with-env.mjs tests/chaos/resilience.mjs",
    "test:finance-hardening": "node scripts/db/run-with-env.mjs tests/chaos/finance-hardening.mjs",
    "test:wave-orchestration": "node scripts/db/run-with-env.mjs tests/chaos/wave-orchestration.mjs",
    "test:p0:isolation": "node scripts/db/run-with-env.mjs tests/product-freight-isolation.mjs",
    "test:p0:entitlements": "node scripts/db/run-with-env.mjs tests/api-product-entitlement.mjs",
    "test:p0:flow": "node scripts/db/run-with-env.mjs scripts/p0-flow-smoke.mjs",
    "test:contract": "node ./scripts/api-contract-smoke.mjs",
    "test:pilot-smoke": "node ./scripts/pilot-smoke.mjs",
    "test:do-compliance": "node ./tests/do-compliance.mjs",
    "check:tenant-safety": "node ./scripts/verify-tenant-safety.mjs",
    "test:policy-acceptance": "node ./tests/policy-acceptance.mjs",
    "quality:gate:web": "npm run lint && npm run test:contract:env && npm run test:isolation",
    "precommit:web": "npm run quality:gate:web",
    "prepare": "husky || true",
    "test:contract:env": "node scripts/run-contract-env.mjs",
    "test:e2e:web-mobile": "node ./scripts/e2e-web-mobile-smoke.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.90.21",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.1.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^6.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "postcss": "^8.5.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^3.4.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
